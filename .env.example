# Copy to `.env` for local shells (never commit `.env`).
# Electron inherits the parent process environment when you launch from a terminal.

# =============================================================================
# Local sidecar — prefix CIH_ (see sidecar/config.py)
# =============================================================================
# CIH_PORT=8420
# CIH_DATA_DIR="${HOME}/Library/Application Support/ContentIntelligenceHub"
# CIH_ANTHROPIC_API_KEY=
# CIH_LLM_MODEL=claude-sonnet-4-6

# =============================================================================
# Electron — cloud vs local (see electron/sidecar.ts)
# =============================================================================
# Use cloud API: do not spawn local Python sidecar when base URL is not localhost.
# CIH_USE_LOCAL_SIDECAR=false
# CIH_API_BASE_URL=https://YOUR-API-XXXXX.run.app

# =============================================================================
# Renderer — Vite build-time (see src/api/runtime.ts)
# =============================================================================
# Must match CIH_API_BASE_URL host for packaged/dev builds that talk to cloud.
# VITE_API_BASE_URL=https://YOUR-API-XXXXX.run.app
# VITE_REQUIRE_AUTH=true
# VITE_API_MODE=cloud

# =============================================================================
# Cloud Run API + worker — prefix CIH_CLOUD_ (see cloud/shared/config.py)
# =============================================================================
# CIH_CLOUD_PORT=8484
# CIH_CLOUD_MAGIC_LINK_SECRET=change-me-in-prod
# CIH_CLOUD_SESSION_SECRET=change-me-in-prod
# CIH_CLOUD_ANTHROPIC_API_KEY=
# CIH_CLOUD_ANTHROPIC_SECRET_REF=anthropic_primary
# CIH_CLOUD_ARTIFACT_BUCKET=your-gcs-bucket
# CIH_CLOUD_GCP_PROJECT_ID=your-project
# CIH_CLOUD_DB_NAME=cih
# CIH_CLOUD_DB_USER=cih_app
# CIH_CLOUD_DB_PASSWORD=
# CIH_CLOUD_DB_HOST=127.0.0.1
# CIH_CLOUD_DB_PORT=5432
# CIH_CLOUD_CLOUDSQL_INSTANCE_CONNECTION_NAME=project:region:instance
# CIH_CLOUD_QUEUE_MODE=inline
# For async jobs (Cloud Tasks → worker):
# CIH_CLOUD_QUEUE_MODE=tasks
# CIH_CLOUD_TASKS_QUEUE=cih-job-queue
# CIH_CLOUD_TASKS_LOCATION=us-central1
# CIH_CLOUD_WORKER_URL=https://YOUR-WORKER-XXXXX.run.app/tasks/jobs
# CIH_CLOUD_TASKS_SERVICE_ACCOUNT_EMAIL=tasks-invoker@...
