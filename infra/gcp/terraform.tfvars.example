# Copy to terraform.tfvars (gitignored) and adjust.
# Do not commit terraform.tfvars.

project_id = "content-intel-hub-prod"
region     = "us-central1"

# Optional hardening (see variables.tf):
# db_tier                = "db-g1-small"
# db_public_ipv4_enabled = true
# db_deletion_protection = true

# Resend magic-link: secret must already exist in Secret Manager (create key + version in Console).
# Short id is the name after .../secrets/ — e.g. CIH_CLOUD_RESEND_API_KEY
# resend_secret_id = "CIH_CLOUD_RESEND_API_KEY"
# If cih-api-prod uses a custom runtime SA, set it (otherwise Terraform uses default compute SA):
# cloud_run_api_service_account_email = "cih-api@content-intel-hub-prod.iam.gserviceaccount.com"

# If Cloud Tasks queue already exists: either import it (see README) or skip Terraform management:
# manage_cloud_tasks_queue = false
